<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <groupId>org.opentcs</groupId>
    <artifactId>opentcs-common-bom</artifactId>
    <version>${revision}</version>
    <packaging>pom</packaging>

    <description>
        opentcs-common 核心基础设施 BOM。
        包含调度系统强依赖的基础能力：持久化、缓存、Web、认证、消息、安全等。
        可选扩展能力（短信/邮件/OSS/社交登录/Excel 等）请引用 opentcs-common-extensions-bom。
    </description>

    <properties>
        <revision>1.0-SNAPSHOT</revision>
    </properties>

    <dependencyManagement>
        <dependencies>
            <!-- ====== 核心基础 ====== -->
            <!-- 公共 DTO / 枚举 / 异常 / R -->
            <dependency>
                <groupId>org.opentcs</groupId>
                <artifactId>opentcs-common-core</artifactId>
                <version>${revision}</version>
            </dependency>

            <!-- API 文档（Springdoc / Swagger）-->
            <dependency>
                <groupId>org.opentcs</groupId>
                <artifactId>opentcs-common-doc</artifactId>
                <version>${revision}</version>
            </dependency>

            <!-- JSON 序列化（Jackson 定制）-->
            <dependency>
                <groupId>org.opentcs</groupId>
                <artifactId>opentcs-common-json</artifactId>
                <version>${revision}</version>
            </dependency>

            <!-- 日志记录（操作日志 AOP）-->
            <dependency>
                <groupId>org.opentcs</groupId>
                <artifactId>opentcs-common-log</artifactId>
                <version>${revision}</version>
            </dependency>

            <!-- Web 公共配置（全局异常、跨域、分页等）-->
            <dependency>
                <groupId>org.opentcs</groupId>
                <artifactId>opentcs-common-web</artifactId>
                <version>${revision}</version>
            </dependency>

            <!-- ====== 数据访问 ====== -->
            <!-- MyBatis Plus 封装 -->
            <dependency>
                <groupId>org.opentcs</groupId>
                <artifactId>opentcs-common-mybatis</artifactId>
                <version>${revision}</version>
            </dependency>

            <!-- 数据库字段加解密 -->
            <dependency>
                <groupId>org.opentcs</groupId>
                <artifactId>opentcs-common-encrypt</artifactId>
                <version>${revision}</version>
            </dependency>

            <!-- 脱敏模块（序列化时脱敏）-->
            <dependency>
                <groupId>org.opentcs</groupId>
                <artifactId>opentcs-common-sensitive</artifactId>
                <version>${revision}</version>
            </dependency>

            <!-- ====== 缓存 / 消息 ====== -->
            <!-- Redisson 缓存 -->
            <dependency>
                <groupId>org.opentcs</groupId>
                <artifactId>opentcs-common-redis</artifactId>
                <version>${revision}</version>
            </dependency>

            <!-- WebSocket（AGV 实时推送）-->
            <dependency>
                <groupId>org.opentcs</groupId>
                <artifactId>opentcs-common-websocket</artifactId>
                <version>${revision}</version>
            </dependency>

            <!-- SSE（Server-Sent Events）-->
            <dependency>
                <groupId>org.opentcs</groupId>
                <artifactId>opentcs-common-sse</artifactId>
                <version>${revision}</version>
            </dependency>

            <!-- MQTT（AGV 设备通信）-->
            <dependency>
                <groupId>org.opentcs</groupId>
                <artifactId>opentcs-common-mqtt</artifactId>
                <version>${revision}</version>
            </dependency>

            <!-- ====== 认证 / 安全 ====== -->
            <!-- Sa-Token JWT -->
            <dependency>
                <groupId>org.opentcs</groupId>
                <artifactId>opentcs-common-satoken</artifactId>
                <version>${revision}</version>
            </dependency>

            <!-- Spring Security 配置 -->
            <dependency>
                <groupId>org.opentcs</groupId>
                <artifactId>opentcs-common-security</artifactId>
                <version>${revision}</version>
            </dependency>

            <!-- ====== 服务能力 ====== -->
            <!-- 限流（令牌桶 / 滑动窗口）-->
            <dependency>
                <groupId>org.opentcs</groupId>
                <artifactId>opentcs-common-ratelimiter</artifactId>
                <version>${revision}</version>
            </dependency>

            <!-- 幂等（防重提交）-->
            <dependency>
                <groupId>org.opentcs</groupId>
                <artifactId>opentcs-common-idempotent</artifactId>
                <version>${revision}</version>
            </dependency>

            <!-- 定时任务（XXL-Job）-->
            <dependency>
                <groupId>org.opentcs</groupId>
                <artifactId>opentcs-common-job</artifactId>
                <version>${revision}</version>
            </dependency>

            <!-- PostgreSQL 驱动 -->
            <dependency>
                <groupId>org.postgresql</groupId>
                <artifactId>postgresql</artifactId>
            </dependency>

            <!-- Spring AI BOM -->
            <dependency>
                <groupId>org.springframework.ai</groupId>
                <artifactId>spring-ai-bom</artifactId>
                <version>1.0.1</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
        </dependencies>
    </dependencyManagement>
</project>
