# OpenTCS Plus 环境变量配置模板
# 复制为 .env 并修改后使用: cp .env.example .env

# ── MySQL ────────────────────────────────────
MYSQL_ROOT_PASSWORD=MySQL@2024!Root
MYSQL_DATABASE=opentcsplus
MYSQL_USER=opentcs
MYSQL_PASSWORD=Opentcs@2024!DB
MYSQL_PORT=3306

# ── Redis ────────────────────────────────────
REDIS_PASSWORD=Redis@2024!Cache
REDIS_PORT=6379

# ── EMQX (MQTT Broker) ───────────────────────
EMQX_DASHBOARD_USER=admin
EMQX_DASHBOARD_PASSWORD=Emqx@2024!Admin
MQTT_PORT=1883
MQTT_WS_PORT=8083
EMQX_DASHBOARD_PORT=18083

# 后端连接 EMQX 的账号 (需在 EMQX Dashboard 中创建)
MQTT_USERNAME=opentcs
MQTT_PASSWORD=Opentcs@2024!MQTT
MQTT_ENABLED=true

# ── 应用服务 ──────────────────────────────────
BACKEND_PORT=8088
FRONTEND_PORT=80

# 应用版本 (与 build-package.sh 生成的镜像 tag 一致)
APP_VERSION=latest
