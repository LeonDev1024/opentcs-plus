<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.opentcs.vehicle.persistence.mapper.VehicleTypeMapper">

    <resultMap type="org.opentcs.vehicle.persistence.entity.VehicleTypeEntity" id="VehicleTypeResult">
        <result property="id" column="id"/>
        <result property="brandId" column="brand_id"/>
        <result property="brandName" column="brand_name"/>
        <result property="name" column="name"/>
        <result property="length" column="length"/>
        <result property="width" column="width"/>
        <result property="height" column="height"/>
        <result property="maxVelocity" column="max_velocity"/>
        <result property="maxReverseVelocity" column="max_reverse_velocity"/>
        <result property="energyLevel" column="energy_level"/>
        <result property="allowedOrders" column="allowed_orders"/>
        <result property="allowedPeripheralOperations" column="allowed_peripheral_operations"/>
        <result property="properties" column="properties"/>
        <result property="createBy" column="create_by"/>
        <result property="updateBy" column="update_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="delFlag" column="del_flag"/>
    </resultMap>

    <sql id="selectVehicleTypeVo">
        SELECT t.id, t.brand_id, b.name as brand_name, t.name, t.length, t.width, t.height, t.max_velocity, t.max_reverse_velocity, t.energy_level, t.allowed_orders, t.allowed_peripheral_operations, t.properties, t.create_by, t.update_by, t.create_time, t.update_time, t.del_flag
        FROM vehicle_type t
        LEFT JOIN brand b ON t.brand_id = b.id AND b.del_flag = '0'
    </sql>

    <select id="selectPageVehicleType" parameterType="org.opentcs.vehicle.persistence.entity.VehicleTypeEntity"
            resultType="org.opentcs.vehicle.persistence.entity.VehicleTypeEntity">
        <include refid="selectVehicleTypeVo"/>
        <where>
            <if test="vehicleType.name != null and vehicleType.name != ''">
                AND t.name LIKE CONCAT('%', #{vehicleType.name}, '%')
            </if>
            <if test="vehicleType.brandId != null">
                AND t.brand_id = #{vehicleType.brandId}
            </if>
            AND t.del_flag = '0'
        </where>
    </select>

</mapper>
